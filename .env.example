# Google Gemini API Key (required)
# Get yours at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Agent ports (optional — defaults shown below)
TELL_TIME_PORT=8001
GREETING_PORT=8002
ORCHESTRATOR_PORT=8003
CLIENT_PORT=8080

# Agent URLs (optional — auto-derived from ports if not set)
# TELL_TIME_URL=http://localhost:8001/
# GREETING_URL=http://localhost:8002/
# ORCHESTRATOR_URL=http://localhost:8003/
